# ─── Better Auth Configuration ───
BETTER_AUTH_SECRET=your_secret_here

# ─── MongoDB ───
MONGO_DB_URI=mongodb+srv://username:password@cluster.mongodb.net
DB_CU=nextrade

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SEC=your_google_client_secret

# ─── Application URLs ───
# Set NEXT_PUBLIC_APP_URL to your deployed client URL on Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000
CLIENT_URI=http://localhost:3000

# Set NEXT_PUBLIC_API_URL to your deployed server URL on Vercel
# e.g., https://nextrade-server.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:8080
